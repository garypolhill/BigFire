    <slider x="10" step="1" y="565" max="30" width="250" display="cell-size" height="50" min="0" direction="Horizontal" default="15.0" variable="cell-size"></slider>
    <slider x="10" step="1" y="345" max="100" width="250" display="moist-level" height="50" min="0" direction="Horizontal" default="60.0" variable="moist-level"></slider>
    <slider x="10" step="1" y="400" max="100" width="250" display="mid-level" height="50" min="0" direction="Horizontal" default="30.0" variable="mid-level"></slider>
    <slider x="10" step="0" y="455" max="100" width="250" display="dry-level" height="50" min="0" direction="Horizontal" default="0.0" variable="dry-level"></slider>
