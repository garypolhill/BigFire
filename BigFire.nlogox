  <linkShapes>
    <shape name="default" curviness="0.0">
      <lines>
        <line x="-0.2" visible="false">
          <dash value="0.0"></dash>
          <dash value="1.0"></dash>
        </line>
        <line x="0.0" visible="true">
          <dash value="1.0"></dash>
          <dash value="0.0"></dash>
        </line>
        <line x="0.2" visible="false">
          <dash value="0.0"></dash>
          <dash value="1.0"></dash>
        </line>
      </lines>
      <indicator>
        <shape name="link direction" rotatable="true" editableColorIndex="0">
          <line endX="90" startY="150" marked="true" color="-1920102913" endY="180" startX="150"></line>
          <line endX="210" startY="150" marked="true" color="-1920102913" endY="180" startX="150"></line>
        </shape>
      </indicator>
    </shape>
  </linkShapes>
  <previewCommands>set density 60.0
setup
repeat 180 [ go ]</previewCommands>
  <experiments>
    <experiment name="BigFireVid" repetitions="1" sequentialRunOrder="true" runMetricsEveryStep="true" timeLimit="10000">
      <setup>setup</setup>
      <go>go</go>
      <exitCondition>not any? turtles</exitCondition>
      <metrics>
        <metric>count fires</metric>
        <metric>count embers</metric>
      </metrics>
      <constants>
        <enumeratedValueSet variable="n-digits">
          <value value="5"></value>
        </enumeratedValueSet>
        <enumeratedValueSet variable="space-dir">
          <value value="&quot;BigFire&quot;"></value>
        </enumeratedValueSet>
        <enumeratedValueSet variable="density">
          <value value="60"></value>
        </enumeratedValueSet>
        <enumeratedValueSet variable="save-space?">
          <value value="true"></value>
        </enumeratedValueSet>
      </constants>
    </experiment>
  </experiments>
</model>
