<?xml version="1.0" encoding="utf-8"?>
<model version="NetLogo 7.0.4" snapToGrid="true">
  <code><![CDATA[globals [
  initial-trees ; how many trees (green patches) we started with
  burned-trees ; how many have burned so far
  wind-dx ; x-component of wind vector
  wind-dy ; y-component of wind vector
  moist-color ; color of the patches with the most moisture
  mid-color ; color of the patches with middle level moisture  
  dry-color ; color of the patches with the least moisture
  mouse-was-down?
  fire-origin-x
  fire-origin-y
]

breed [fires fire] ; bright red turtles -- the leading edge of the fire
breed [embers ember] ; turtles gradually fading from red to near black
breed [spotters spotter] ; airborn embers carried by wind

patches-own [
  ;moisture ; 0 (dry) to 100 (saturated)
  is-tree? ; determines if a patch is a tree or space
  cell-x ; which macro-cell column this patch belongs to
  cell-y ; which macro-cell row this patch belongs to
  zone-type
]

spotters-own [
  birth-tick ; when the ember was launched
  travel-speed ; how fast this ember moves per tick
]



to setup
  clear-all
  set-default-shape turtles "square"
  
  ; establish moisture colors (lighter is dryer)
  set moist-color green - 2
  set mid-color green
  set dry-color green + 2 
  
  ; initialize all patches as trees
  ask patches [
    set is-tree? TRUE
  ]
  
  ; add moisture clusters and incorporate denisty by creating non tree patches
  generate-moisture-zones
  apply-moisture-and-density
  
  ; get wind direction's x and y components
  set wind-dx sin wind-direction
  set wind-dy cos wind-direction

  set fire-origin-x int ((max-pxcor + min-pxcor) / 2)
  set fire-origin-y int ((max-pycor + min-pycor) / 2)

  ; initiale initial condition (starting fire does not count towards the percentage burned)
  set initial-trees count patches with [is-tree?]
  set burned-trees 0
  
  start-fire

  reset-ticks
end

to go  
  
  ask fires [
    let fire-patch patch-here
    ask neighbors4 with [is-tree?] [
      let base-chance 100 - moisture ; less chance to ignite if there is more moisture
      let bonus wind-spread-bonus fire-patch self ; more likely to spread if wind is in the direction of patch from the pach on fire
      let spread-chance bound(base-chance + bonus) 0 100
      if (random-float 1 * threshold) < spread-chance [ ignite ]
     ]
    set breed embers 
  ]
  
  ; add in spotting embers and let them travel with the wind
  launch-spotters
  move-spotters
  
  ; visually fade other embers
  fade-embers
  tick
  if save-space? [
    let max-ticks 10 ^ n-digits
    ifelse ticks < max-ticks [
      save-space space-dir n-digits
    ] [
      stop
    ]
  ]
end

to start-fire
  ifelse start-condition = "center-line" [
    ; Start a fire in a line in the center
    ask patches with [pxcor = int (world-width / 2)]
    [ ignite ]
  ]
  [ ifelse start-condition = "center circle" [
    ; Start fire in a circle in the center
    let cx int ((max-pxcor + min-pxcor) / 2)
    let cy int ((max-pycor + min-pycor) / 2)
    ask patches with [
      (pxcor - cx) ^ 2 + (pycor - cy) ^ 2 < fire-start-radius ^ 2
    ] [
      ignite
    ]
    
    ]
    [ ifelse start-condition = "bbq-on-dry" [
      ; start a small bbq fire on a dy patch near the center
      
       let cx int ((max-pxcor + min-pxcor) / 2)
      let cy int ((max-pycor + min-pycor) / 2)

      let bbq-patch nobody
      let search-radius 1
      let max-search (min (list world-width world-height) / 2)

      while [bbq-patch = nobody and search-radius < max-search] [
        set bbq-patch one-of patches with [
          is-tree? and
          zone-type = 0 and
          abs (pxcor - cx) <= search-radius and
          abs (pycor - cy) <= search-radius
        ]
        set search-radius search-radius + 1
      ]

      ifelse bbq-patch != nobody [
        ; Ignite a small circle of radius 5 around the dry patch found
        let bx [pxcor] of bbq-patch
        let by [pycor] of bbq-patch
        ask patches with [
          (pxcor - bx) ^ 2 + (pycor - by) ^ 2 <= 25
        ] [
          ignite
        ]
      ] [
        ; Fallback — small circle around nearest tree to center
        let fallback min-one-of patches with [is-tree?] [distancexy cx cy]
        if fallback != nobody [
          let bx [pxcor] of fallback
          let by [pycor] of fallback
          ask patches with [
            (pxcor - bx) ^ 2 + (pycor - by) ^ 2 <= 25
          ] [
            ignite
          ]
        ]
      ]
      ]
      [
        error("Unknown start-condition")
      ]
    ]
  ]
end

; creates the fire turtles
to ignite  ; patch procedure
  if is-tree? [
    set is-tree? FALSE
    sprout-fires 1
    [ set color red ]
    set pcolor black
    set burned-trees burned-trees + 1
  ]
end

; achieve fading color effect for the fire as it burns
to fade-embers
  ask embers
    [ set color color - 0.3  ; make red darker
      if color < red - 3.5
        [ set pcolor color
          die ] ]
end

; calculate the increased chance of a spot igniting due to wind
to-report wind-spread-bonus [from-patch to-patch]
  
  ifelse wind-type = "to-wind-direction" [
    ; Calculate wind effect in direction of wind-direction
    let patch-dx ([pxcor] of to-patch - [pxcor] of from-patch)
    let patch-dy ([pycor] of to-patch - [pycor] of from-patch)
  
    let alignment patch-dx * wind-dx + patch-dy * wind-dy 
  
    report alignment * wind-speed * 2
  ]
  [
    ifelse wind-type = "from-center" [
      ; Calculate wind effect in direction away from center
      let patch-dx ([pxcor] of to-patch - [pxcor] of from-patch)

      ;; Horizontal distance from centerline determines wind direction
      ;; Positive = right of center (wind blows right)
      ;; Negative = left of center (wind blows left)
      let radial-dx [pxcor] of from-patch - fire-origin-x

      ;; Normalize to just the sign — pure left or pure right
      ;; Add small epsilon to avoid division by zero at exact center
      let wind-ux radial-dx / (abs radial-dx + 0.001)

      ;; Alignment is just how much the spread direction matches the wind direction
      let alignment patch-dx * wind-ux

      report alignment * sqrt(wind-speed) * 2
    ]
    [
      error("Unknown wind-type")
    ]
  ]
end

; launch spotting embers and set them in the direction of the wind
to launch-spotters
  ask fires [
    let launch-chance spotting-probability * (wind-speed / 10)
    if random-float 100 < launch-chance [
      let speed 0.5 + random-float (wind-speed * 0.8)

      ;; Heading depends on wind type
      let spotter-heading 0
      
      ifelse wind-type = "to-wind-direction" [
        ;; Fixed global wind direction
        set spotter-heading wind-direction + (random-float 40 - 20)
      ] [
        ;; Radial — head left or right based on side of centerline
        let horizontal-sign xcor - fire-origin-x
        let base-heading ifelse-value (horizontal-sign >= 0) [90] [270]
        set spotter-heading base-heading + (random-float 20 - 10)
      ]

      hatch-spotters 1 [
        set color orange + 2
        set shape "circle"
        set size 0.8
        set birth-tick ticks
        set travel-speed speed
        set heading spotter-heading
      ]
    ]
  ]
end

; moves the spotters in the direction of the wind until they ignite something or their lifespan runs out
to move-spotters
  ask spotters [
    set heading heading + (random-float 10 - 5)
    forward travel-speed
    
    if is-tree? [
      let ignition-chance (100 - moisture) * (spotting-probability / 10)
      if threshold < ignition-chance [
        ask patch-here [ ignite ]
      ]
      die
    ]
    
    if (ticks - birth-tick) >= max-ember-lifetime [die]
  ]
end

; create macro cells to help create clusters
to assign-macro-cells
  ask patches [
    ; maps each patch to its parent macro-cell coordinate
    set cell-x floor (pxcor / cell-size)
    set cell-y floor (pycor / cell-size)
  ]
end

; randomly disperse the three moisture vales to the macro-cells
to initialize-macro-cells
  ; assign a random moisture color to each macro-cell by setting the bottom-left patch of each cell first
  ask patches with [
    pxcor mod cell-size = 0 and
    pycor mod cell-size = 0
  ] [
    set pcolor one-of (list moist-color mid-color dry-color)
  ]

  ; extend each cell's color to all patches within it
  ask patches [
    let cx cell-x * cell-size
    let cy cell-y * cell-size
    set pcolor [pcolor] of patch cx cy
  ]
end

; uses macro-cells and rps to add variety to create organic blobs
to generate-moisture-zones
  assign-macro-cells
  initialize-macro-cells
  
  ; run rps competition for a certain number of iterations
  repeat moisture-iterations [
    ; for time, only consider patches that border a patch of a different type
    let boundary-patches patches with [
      any? neighbors4 with [pcolor != [pcolor] of myself]
    ]
    ask boundary-patches [
      let target one-of neighbors4
      ; 50/50 chance of swap vs select each event
      ifelse random 2 = 0 [
        rps-swap target
      ] [
        rps-select target
      ]
    ]
  ]
end

; swap colors between two patches
to rps-swap [target]
  let old-color pcolor
  set pcolor [pcolor] of target
  ask target [set pcolor old-color]
end

; the loser of a competition takes the winner's color
to rps-select [target]
  ifelse rps-beats? target [
    ; I win and target becomes my color
    ask target [set pcolor [pcolor] of myself]
  ] [
    if [rps-beats? myself] of target [
      ; Target wins and I become target's color
      set pcolor [pcolor] of target
    ]
  ]
end

; determines if this patch beats the target
; the cycle is arbitrary: moist beats mid, mid beats dry, dry beats moist
to-report rps-beats? [target]
  let my-color pcolor
  let their-color [pcolor] of target
  report (my-color = moist-color and their-color = mid-color) or
         (my-color = mid-color   and their-color = dry-color) or
         (my-color = dry-color   and their-color = moist-color)
end

; assign moisture values based on color and then add in the density
to apply-moisture-and-density
  ask patches [
    ;; Assign numeric moisture based on zone color
    if pcolor = moist-color [ set zone-type 2 ]
    if pcolor = mid-color   [ set zone-type 1 ]
    if pcolor = dry-color   [ set zone-type 0 ]

    ;; Apply density — remove trees randomly regardless of moisture zone
    ifelse random-float 100 < density [
      set is-tree? true
    ] [
      set is-tree? false
      set pcolor black
    ]
  ]
end

; ensures a value is bounded between a range
to-report bound[val low high]
  report max(list low (min(list high val)))
end

to-report moisture
  if zone-type = 2 [ report moist-level ]
  if zone-type = 1 [ report mid-level ]
  if zone-type = 0 [ report dry-level ]
  report 0  ; fallback for non-tree patches
end

to color-by-zone
  ask patches with [is-tree?] [
    if zone-type = 2 [ set pcolor moist-color ]
    if zone-type = 1 [ set pcolor mid-color   ]
    if zone-type = 0 [ set pcolor dry-color   ]
  ] 
end


;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

to handle-click
  if mouse-down? [
    if not mouse-was-down? [  ; Only trigger on fresh click, not hold
      ask patch mouse-xcor mouse-ycor [
        ignite
      ]
      set mouse-was-down? true
    ]
  ]
  if not mouse-down? [
    set mouse-was-down? false  ; Reset when mouse is released
  ]
end

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;


; Started from the Fire model in the model library
; Copyright 1997 Uri Wilensky.
; See Info tab for full copyright and license.

to save-space [ dir padding ]
  let digits 1 + int log ticks 10
  let n-zeros ifelse-value (length (word ticks) < padding) [
    reduce [ [a b] -> (word a b) ] n-values (padding - digits) [ i -> 0 ]
  ] [
    ""
  ]
  let filename (word dir "/view-" n-zeros ticks ".png")
  export-view filename
end]]></code>
  <widgets>
    <view x="280" wrappingAllowedX="false" y="110" frameRate="30.0" minPycor="0" height="523" showTickCounter="true" patchSize="0.86563" fontSize="10" wrappingAllowedY="false" width="6929" tickCounterLabel="ticks" maxPycor="599" updateMode="1" maxPxcor="7999" minPxcor="0"></view>
    <slider x="10" step="1.0" y="70" max="99.0" width="250" display="density" height="50" min="0.0" direction="Horizontal" default="60.0" variable="density" units="%"></slider>
    <button x="15" y="15" height="45" disableUntilTicks="false" forever="false" kind="Observer" width="80" display="setup">setup</button>
